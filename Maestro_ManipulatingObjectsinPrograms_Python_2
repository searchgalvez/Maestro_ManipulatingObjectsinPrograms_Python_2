class Hero:
    def __init__(self, name, hp, mana):
        self.name = name
        self.hp = hp
        self.mana = mana

    def heal(self, amount):
        self.hp += amount
        return amount

heroes = [
    Hero("Mage", 40, 80),
    Hero("Warrior", 70, 20),
    Hero("Rogue", 50, 40),
]

total_healed = 0

for hero in heroes:
    healed = hero.heal(5)   # changes hero.hp
    total_healed += healed  # aggregates

print("Total healed:", total_healed)
print("Final HPs:")
for hero in heroes:
    print(hero.name, hero.hp)
